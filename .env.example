# Sao chép file này thành ".env" và điền giá trị thật
# .env KHÔNG được commit lên git (đã trong .gitignore)

# Jira instance URL (KHÔNG có dấu / cuối)
JIRA_URL=https://jira.baokim.vn:8443

# Personal Access Token - tạo tại: Profile → Personal Access Tokens → Create token
# Quyền cần: Browse Projects
JIRA_PAT=paste_your_pat_here

# Username các thành viên QA team (cách nhau bằng dấu phẩy)
JIRA_USERS=quangbm,nhungnh,phuongct,tholt,thanhht1

# Cổng local server (đổi nếu 8080 bị chiếm)
JIRA_PORT=8080

# Nhịp poll Drive (giây) của Bug Log background sync. Default 600 (10 phút).
# Nhờ Tầng-1 metadata-first, mỗi poll khi không file nào đổi rất nhẹ -> hạ xuống
# 120-180 (2-3 phút) vẫn an toàn nếu muốn bug log tươi hơn. Sàn tối thiểu 30s.
BUG_LOG_POLL_SECONDS=600

# Trần số call Jira REST đồng thời (an toàn khi bật đa luồng — issue #129/#133).
# Chặn nhiều tab + ThreadPool lồng nhân số request lên làm nện Jira DC / cạn socket.
# Default 12, clamp [1, 64]. pool_maxsize của session tự đặt khớp giá trị này.
JIRA_MAX_CONCURRENT=12

# ===== Chatbot AI (LLM local qua Ollama, Decision #32) =====
# Ollama chạy CÙNG host. Bỏ trống OLLAMA_MODEL = tắt chatbot (widget không render).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
# Model nằm thường trú GPU/RAM bao lâu sau request cuối.
#   '10m' = nhả sau 10p không dùng (DEFAULT — hợp máy 16GB: model 12B 8GB ghim mãi gây swap;
#           nhả khi rảnh để giải phóng RAM, chỉ câu đầu sau idle chịu ~30s nạp lại).
#   '-1'  = giữ mãi (không cold-load nhưng swap liên tục — chỉ hợp máy nhiều RAM).
#   '0'   = nhả ngay sau mỗi câu.
OLLAMA_KEEP_ALIVE=10m

# ----- Cấu hình Email gửi báo cáo tự động -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RECEIVER_EMAIL=

# ===== Auth / phân quyền =====
# Cả 2 để TRỐNG = không khoá gì (chạy local thoải mái).

# Email role ADMIN: người DUY NHẤT được edit/xoá roadmap + tài liệu. Người khác chỉ xem.
JIRA_ADMIN_EMAIL=thanhht1@baokim.vn

# Username Jira của chính admin — dùng cho tab "Việc của tôi" (/my-work) lọc task riêng.
# Trống/local dev → mặc định thanhht1.
JIRA_SELF_USER=thanhht1

# Domain được phép vào. Vd: baokim.vn → chỉ email @baokim.vn login được. Trống = không chặn.
JIRA_ALLOWED_DOMAIN=baokim.vn

# ===== Google OAuth login (golive: thay Cloudflare Access) =====
# Điền đủ CLIENT_ID + CLIENT_SECRET => app BẮT đăng nhập Google, lọc theo JIRA_ALLOWED_DOMAIN.
# Bỏ trống => local dev: không bắt login (mọi request = admin).
# Tạo tại: console.cloud.google.com → APIs & Services → Credentials → Create OAuth client ID
#   → Web application → Authorized redirect URIs:
#        https://baokim-qa.com/oauth/callback
#        http://localhost:8080/oauth/callback   (để test local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Khoá ký session cookie (HMAC). BẮT BUỘC khi bật Google OAuth. Tạo bằng:
#   python3 -c "import secrets;print(secrets.token_urlsafe(48))"
# Khoá HMAC cookie + khoá mã hoá PAT được DERIVE tách-miền từ đây (issue #45) nên 1 secret
# vẫn không bị tái dùng cho 2 vai trò.
# ROTATE: đổi SESSION_SECRET => (a) mọi session hết hiệu lực (login lại — rẻ) VÀ (b) nếu
# KHÔNG set PAT_SECRET riêng thì khoá mã hoá PAT cũng đổi => 5 QA phải dán lại PAT ở /settings.
SESSION_SECRET=

# (tùy chọn) Khoá RIÊNG mã hoá PAT cá nhân at-rest (issue #45). Bỏ trống => dùng chung
# SESSION_SECRET (PAT đã lưu vẫn giải mã được). Set giá trị riêng (token_urlsafe(48)) để
# TÁCH blast radius: rotate SESSION_SECRET không còn xoá PAT. ⚠ Đổi PAT_SECRET = re-enter PAT.
PAT_SECRET=

# URL gốc công khai khi golive (vd https://baokim-qa.com). Khi set => app dùng cái này
# để build redirect_uri OAuth + quyết cờ Secure cookie, KHÔNG tin Host/X-Forwarded-Proto
# do client gửi (chống Host-header injection — issue #49). Bỏ trống => suy từ request
# (local dev). KHUYẾN NGHỊ set khi chạy prod sau cloudflared.
PUBLIC_BASE_URL=

# ===== Cloudflare Workers KV = kho sync chéo máy KHÔNG cần VPN =====
# Dùng làm kho chung cho roadmap/tài liệu/custom-status/PAT (thay Jira property — vốn sau
# VPN nên mất VPN = save fail). Điền ĐỦ cả 3 => bật KV. Bỏ trống => fallback Jira property
# (vẫn local-first nên save không fail vì mạng, nhưng sync chéo máy lại cần VPN).
# Lấy giá trị: Cloudflare dashboard → Storage & Databases → KV (tạo namespace) + My Profile
# → API Tokens (token quyền Account · Workers KV Storage · Edit). DÙNG CHUNG 3 giá trị này
# trên mọi host (Mac/Win) để trỏ cùng 1 namespace.
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=
