# Sao chép file này thành ".env" và điền giá trị thật
# .env KHÔNG được commit lên git (đã trong .gitignore)

# Jira instance URL (KHÔNG có dấu / cuối)
JIRA_URL=https://jira.baokim.vn:8443

# Personal Access Token - tạo tại: Profile → Personal Access Tokens → Create token
# Quyền cần: Browse Projects
JIRA_PAT=paste_your_pat_here

# Username các thành viên QA team (cách nhau bằng dấu phẩy)
JIRA_USERS=quangbm,nhungnh,phuongct,tholt,thanhht1

# Cổng local server (đổi nếu 8080 bị chiếm)
JIRA_PORT=8080
