# Sao chép file này thành ".env" và điền giá trị thật
# .env KHÔNG được commit lên git (đã trong .gitignore)

# Jira instance URL (KHÔNG có dấu / cuối)
JIRA_URL=https://jira.baokim.vn:8443

# Personal Access Token - tạo tại: Profile → Personal Access Tokens → Create token
# Quyền cần: Browse Projects
JIRA_PAT=paste_your_pat_here

# Username các thành viên QA team (cách nhau bằng dấu phẩy)
JIRA_USERS=quangbm,nhungnh,phuongct,tholt,thanhht1

# Cổng local server (đổi nếu 8080 bị chiếm)
JIRA_PORT=8080

# ===== Auth / phân quyền =====
# Cả 2 để TRỐNG = không khoá gì (chạy local thoải mái).

# Email role ADMIN: người DUY NHẤT được edit/xoá roadmap + tài liệu. Người khác chỉ xem.
JIRA_ADMIN_EMAIL=thanhht1@baokim.vn

# Username Jira của chính admin — dùng cho tab "Việc của tôi" (/my-work) lọc task riêng.
# Trống/local dev → mặc định thanhht1.
JIRA_SELF_USER=thanhht1

# Domain được phép vào. Vd: baokim.vn → chỉ email @baokim.vn login được. Trống = không chặn.
JIRA_ALLOWED_DOMAIN=baokim.vn

# ===== Google OAuth login (golive: thay Cloudflare Access) =====
# Điền đủ CLIENT_ID + CLIENT_SECRET => app BẮT đăng nhập Google, lọc theo JIRA_ALLOWED_DOMAIN.
# Bỏ trống => local dev: không bắt login (mọi request = admin).
# Tạo tại: console.cloud.google.com → APIs & Services → Credentials → Create OAuth client ID
#   → Web application → Authorized redirect URIs:
#        https://baokim-qa.com/oauth/callback
#        http://localhost:8080/oauth/callback   (để test local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Khoá ký session cookie (HMAC). BẮT BUỘC khi bật Google OAuth. Tạo bằng:
#   python3 -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
